cat("\n==========================================================\n")
cat("QUESTION A3\n")
cat("==========================================================\n\n")

# State space: 1=Light, 2=Heavy, 3=Jammed
states3 <- c("Light","Heavy","Jammed")

# Transition matrix 1PM-4PM
# All rows sum to 1.0 (valid stochastic matrix)
A <- matrix(c(
  0.4, 0.4, 0.2,
  0.3, 0.4, 0.3,   # Heavy row: 0.3+0.4+0.3 = 1.0 (correct)
  0.0, 0.1, 0.9
), nrow = 3, byrow = TRUE)
rownames(A) <- colnames(A) <- states3

# Transition matrix 4PM-6PM
B <- matrix(c(
  0.1, 0.5, 0.4,
  0.1, 0.3, 0.6,
  0.0, 0.1, 0.9
), nrow = 3, byrow = TRUE)
rownames(B) <- colnames(B) <- states3

cat("Matrix A (1PM - 4PM, every 20 min):\n"); print(A)
cat("Row sums of A:", rowSums(A), "\n")

cat("\nMatrix B (4PM - 6PM, every 20 min):\n"); print(B)
cat("Row sums of B:", rowSums(B), "\n")

# ------------------------------------------------------------------
# Part (a): Analytical distribution at 6PM
# ------------------------------------------------------------------
cat("\n--- Part (a): Distribution at 6PM ---\n")
cat("1PM to 4PM = 3 hours / 20 min intervals = 9 transitions  => A^9\n")
cat("4PM to 6PM = 2 hours / 20 min intervals = 6 transitions  => B^6\n\n")

# Compute A^9
An <- diag(3)
for (i in 1:9) An <- An %*% A

# Compute B^6
Bn <- diag(3)
for (i in 1:6) Bn <- Bn %*% B

cat("A^9 (9-step transition matrix, 1PM-4PM period):\n")
print(round(An, 6))

cat("\nB^6 (6-step transition matrix, 4PM-6PM period):\n")
print(round(Bn, 6))

# Initial distribution at 1PM: starts in Light state
pi_1pm <- c(1, 0, 0)

# Distribution at 4PM = pi_1pm * A^9
pi_4pm <- pi_1pm %*% An
cat("\nDistribution at 4PM (pi_1pm %*% A^9):\n")
print(round(pi_4pm, 6))
cat(sprintf("  P(Light at 4PM)  = %.4f  (10.05%%)\n", pi_4pm[1]))
cat(sprintf("  P(Heavy at 4PM)  = %.4f  (19.00%%)\n", pi_4pm[2]))
cat(sprintf("  P(Jammed at 4PM) = %.4f  (70.95%%)\n", pi_4pm[3]))

# Distribution at 6PM = pi_4pm * B^6
pi_6pm <- pi_4pm %*% Bn
cat("\nDistribution at 6PM (pi_4pm %*% B^6):\n")
print(round(pi_6pm, 6))
cat(sprintf("  P(Light at 6PM)  = %.4f  (1.48%%)\n",  pi_6pm[1]))
cat(sprintf("  P(Heavy at 6PM)  = %.4f  (13.26%%)\n", pi_6pm[2]))
cat(sprintf("  P(Jammed at 6PM) = %.4f  (85.26%%)\n", pi_6pm[3]))

cat("\nInterpretation:\n")
cat("  Starting from Light at 1PM, by 6PM the traffic is almost certainly Jammed\n")
cat("  (85.26%). By 4PM it is already predominantly Jammed (70.95%). The Jammed\n")
cat("  state has a very high self-persistence of 0.9 in both periods, acting as a\n")
cat("  near-absorbing state. There is only a 1.48% chance of returning to Light\n")
cat("  and a 13.26% chance of being Heavy by 6PM.\n")

# ------------------------------------------------------------------
# Part (b): Monte Carlo simulation with 10,000 trajectories
# ------------------------------------------------------------------
cat("\n--- Part (b): Monte Carlo Simulation (10,000 trajectories) ---\n")

set.seed(123)
n_sim <- 10000

simulate_traffic <- function() {
  state <- 1  # Start at Light (1PM)
  
  # 9 transitions using matrix A (1PM to 4PM)
  for (step in 1:9) {
    state <- sample(1:3, 1, prob = A[state, ])
  }
  
  # 6 transitions using matrix B (4PM to 6PM)
  for (step in 1:6) {
    state <- sample(1:3, 1, prob = B[state, ])
  }
  
  return(state)
}

final_states <- sapply(1:n_sim, function(x) simulate_traffic())
sim_probs    <- table(final_states) / n_sim

cat("Simulated distribution at 6PM (from 10,000 runs):\n")
sim_df <- data.frame(
  State      = states3,
  Analytical = as.numeric(round(pi_6pm, 4)),
  Simulated  = as.numeric(sim_probs[c("1", "2", "3")])
)
print(sim_df)

cat("\nAbsolute differences |Analytical - Simulated|:\n")
cat(sprintf("  Light:  %.4f\n", abs(sim_df$Analytical[1] - sim_df$Simulated[1])))
cat(sprintf("  Heavy:  %.4f\n", abs(sim_df$Analytical[2] - sim_df$Simulated[2])))
cat(sprintf("  Jammed: %.4f\n", abs(sim_df$Analytical[3] - sim_df$Simulated[3])))

# Bar plot comparison
barplot(
  rbind(sim_df$Analytical, sim_df$Simulated),
  beside      = TRUE,
  names.arg   = states3,
  col         = c("yellow", "red"),
  legend.text = c("Analytical", "Simulated"),
  main        = "A3: Traffic State Distribution at 6PM",
  ylab        = "Probability",
  ylim        = c(0, 1),
  args.legend = list(x = "topright")
)

cat("\nConclusion:\n")
cat("  The simulated probabilities agree closely with the analytical values,\n")
cat("  confirming the matrix multiplication result is correct.\n")
cat("  Maximum difference across all states is < 0.002, well within the expected\n")
cat("  Monte Carlo sampling error of sqrt(p*(1-p)/10000) < 0.005.\n")
cat("  At 6PM the traffic is overwhelmingly likely to be Jammed (~85.26%),\n")
cat("  with a small chance of Heavy (~13.26%) and very unlikely to be Light (~1.48%).\n")
